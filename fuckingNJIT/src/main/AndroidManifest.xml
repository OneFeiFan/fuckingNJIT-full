<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.REQUEST_INSTALL_PACKAGES" />
    <uses-permission android:name="android.permission.INTERNET" /> <!-- 允许 App 访问网络（认证时发送请求需要） -->
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" /> <!-- 允许检查网络状态（绑定网络进程需要） -->
    <uses-permission android:name="android.permission.CHANGE_NETWORK_STATE" /><!-- 允许改变网络状态（某些 ROM 兼容性需要） -->

    <!-- 基础权限 -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.VIBRATE" />
    <uses-permission android:name="android.permission.WAKE_LOCK" />
    <uses-permission android:name="android.permission.INTERNET" />

    <!-- 硬件访问权限 -->
    <uses-permission android:name="android.permission.RECORD_AUDIO" />

    <!-- 系统状态监测 -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" /> <!-- Android 13+ -->
    <uses-permission android:name="android.permission.REQUEST_IGNORE_BATTERY_OPTIMIZATIONS" />

    <!-- Android 14 (API 34) 必须声明具体的前台服务类型权限 -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MICROPHONE" />
    <uses-permission android:name="android.permission.SCHEDULE_EXACT_ALARM" />


    <uses-permission
        android:name="android.permission.WRITE_EXTERNAL_STORAGE"
        android:maxSdkVersion="28" />

    <uses-permission android:name="android.permission.ACTIVITY_RECOGNITION" />

    <queries>
        <intent>
            <action android:name="android.net.conn.CAPTIVE_PORTAL" />
        </intent>
    </queries>

    <application android:usesCleartextTraffic="true">
        <!-- 易班登录 -->
        <activity
            android:name=".utils.academic.KillYiBan"
            android:enabled="false"
            android:excludeFromRecents="true"
            android:exported="true"
            android:icon="@drawable/killyiban"
            android:label="Kill易班"
            android:taskAffinity=".utils.KillYiBan">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
        <!-- 内嵌WebView -->
        <activity
            android:name=".service.impl.SampleWebViewImpl"
            android:configChanges="orientation|screenSize|keyboardHidden|smallestScreenSize"
            android:excludeFromRecents="true"
            android:theme="@style/Theme.FuckingNJIT" />
        <!-- 课表小组件 -->
        <activity
            android:name=".widget.CurriculumsWidgetConfigActivity"
            android:exported="false">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_CONFIGURE" />
            </intent-filter>
        </activity>
        <!-- WIFI认证 -->
        <activity
            android:name=".utils.network.wifiauth.PortalActivity"
            android:enabled="false"
            android:excludeFromRecents="true"
            android:exported="true"
            android:taskAffinity="">

            <!-- 拦截系统 WiFi 认证信号 -->
            <intent-filter>
                <action android:name="android.net.conn.CAPTIVE_PORTAL" />
                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>
        </activity>

        <receiver
            android:name=".widget.CurriculumsWidgetProvider"
            android:exported="true">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
                <action android:name="com.feifan.fuckingnjit.ACTION_GLOBAL_TICK" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/curriculums_widget_provider" />
        </receiver>

        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>

        <provider
            android:name="androidx.startup.InitializationProvider"
            android:authorities="${applicationId}.androidx-startup"
            android:exported="false"
            tools:node="merge">
            <!-- 注册你的初始化器 -->
            <meta-data
                android:name="com.feifan.fuckingnjit.utils.database.CoreInitProvider"
                android:value="androidx.startup" />
        </provider>


        <!-- 核心服务：必须声明 foregroundServiceType -->
        <service
            android:name=".service.CoreService"
            android:enabled="true"
            android:exported="false"
            android:foregroundServiceType="mediaPlayback|microphone" />
        <service
            android:name=".monitor.AppUsageManager"
            android:exported="true"
            android:label="@string/app_name"
            android:permission="android.permission.BIND_ACCESSIBILITY_SERVICE">
            <intent-filter>
                <action android:name="android.accessibilityservice.AccessibilityService" />
            </intent-filter>

            <meta-data
                android:name="android.accessibilityservice"
                android:resource="@xml/accessibility_config" />
        </service>
    </application>
</manifest>